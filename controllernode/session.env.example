# Session Configuration for Test Drive
# Define roles and parameters for throughput testing

# The iperf3 server address (AWS, public IP)
IPERF_SERVER="1.2.3.4"

# Assign roles to node names defined in config.env
DOWNLINK_NODE="apu3"
UPLINK_NODE="apu3lte"

# Burst duration in seconds. Shorter = better spatial resolution.
# At 50 km/h: 5s ≈ 70m, 10s ≈ 140m per measurement.
BURST_DURATION=10

# Pause between bursts in seconds
BURST_INTERVAL=1

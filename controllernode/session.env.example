# Session Configuration for Test Drive
# Define roles and parameters for throughput testing

# The iperf3 server address (public IP or accessible via VPN)
IPERF_SERVER="1.2.3.4"

# Assign roles to node names defined in config.env
DOWNLINK_NODE="apu3lte"
UPLINK_NODE="apu3"

# Individual test duration in seconds (shorter gives better spatial resolution)
BURST_DURATION=5

# Interval between bursts in seconds
BURST_INTERVAL=2

# Controller Configuration Example
# Format: "node_name|addr|ssh_user"
# addr is used directly for SSH — edit to match your current environment.
# At home: use hostname. During a test drive: use the field IP.
NODES=(
    # --- At home ---
    "node1|node1|admin"
    "node2|node2|pi"
    # --- Test drive ---
    # "node1|192.168.3.2|admin"
    # "node2|192.168.3.3|pi"
)

REMOTE_REPO_ROOT="/path/to/repo"
REMOTE_BASE_DATADIR="$HOME/datadir"
LOCAL_BASE_DATADIR="$HOME/datadir"

# AWS Configuration for iperf server port management
AWS_REGION="eu-central-1"
# The Security Group ID protecting your AWS iperf server
AWS_SECURITY_GROUP_ID="sg-0123456789abcdef0"
# The ports to open (iperf3 default is 5201)
IPERF_PORTS="5201,5202"
